---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { altLocalePath, type Locale } from '../lib/i18n';
import '../styles/global.css';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** Landing-page mode: no nav links / footer columns, single CTA focus. */
  minimal?: boolean;
  ogImage?: string;
}
const { locale, title, description, minimal = false, ogImage = '/sfx30.webp' } = Astro.props;
const site = 'https://miamiphotographycenter.com';
const pathname = Astro.url.pathname;
const canonical = `${site}${pathname === '/' ? '' : pathname}`;
const altPath = altLocalePath(locale, pathname);
const altUrl = `${site}${altPath === '/' ? '' : altPath}`;
const enUrl = locale === 'en' ? canonical : altUrl;
const esUrl = locale === 'es' ? canonical : altUrl;
---
<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#1d1d1f" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="es" href={esUrl} />
  <link rel="alternate" hreflang="x-default" href={enUrl} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Miami Photography Center" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${site}${ogImage}`} />
  <meta property="og:locale" content={locale === 'es' ? 'es_US' : 'en_US'} />
  <meta property="og:locale:alternate" content={locale === 'es' ? 'en_US' : 'es_US'} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${site}${ogImage}`} />

  <link rel="icon" href="/favicon.ico?v=3" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=3" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=3" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" />

  <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" />

  <script src="/scripts/vendor/gsap.min.js" defer is:inline></script>
  <script src="/scripts/vendor/ScrollTrigger.min.js" defer is:inline></script>
  <script src="/scripts/vendor/lenis.min.js" defer is:inline></script>
  <script src="/scripts/main.js?v=8" defer is:inline></script>

  <slot name="head" />
</head>

<body class={minimal ? 'is-landing' : undefined}>
  <a href="#main" class="skip-link">{locale === 'es' ? 'Saltar al contenido' : 'Skip to content'}</a>
  {minimal ? (
    <nav class="nav nav--minimal" aria-label="Primary">
      <div class="nav__inner">
        <span class="nav__brand">MPC — Miami Photography Center</span>
        <a href="tel:+17867632091" class="nav__cta">{locale === 'es' ? 'Llamar (786) 763-2091' : 'Call (786) 763-2091'}</a>
      </div>
    </nav>
  ) : (
    <Nav locale={locale} />
  )}

  <main id="main">
    <slot />
  </main>

  {!minimal && <Footer locale={locale} />}
  {minimal && (
    <footer class="footer footer--minimal" aria-label="Site footer">
      <div class="footer__bottom" style="margin-top:0;border-top:0;">
        <p>&copy; {new Date().getFullYear()} Miami Photography Center · 3911 SW 27th St, West Park, FL 33023 · <a href="tel:+17867632091">+1 (786) 763-2091</a></p>
      </div>
    </footer>
  )}

  <a
    class="wa-fab"
    href={`https://wa.me/17866811643?text=${encodeURIComponent(locale === 'es' ? 'Hola, vengo de la web de Miami Photography Center y quisiera más información.' : 'Hi, I found you on the Miami Photography Center website and would like more information.')}`}
    target="_blank"
    rel="noopener"
    aria-label="WhatsApp"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.738-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
  </a>
</body>
</html>

<style is:global>
  .wa-fab {
    position: fixed;
    right: clamp(16px, 3vw, 28px);
    bottom: clamp(16px, 3vw, 28px);
    z-index: 1000;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .wa-fab:hover {
    transform: scale(1.06);
    box-shadow: 0 8px 26px rgba(0, 0, 0, 0.3);
  }
  .wa-fab svg {
    width: 30px;
    height: 30px;
    fill: #fff;
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-fab { transition: none; }
  }
</style>
