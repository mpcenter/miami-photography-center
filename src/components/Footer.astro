---
import { localePath, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = locale === 'es'
  ? {
      services: 'Servicios',
      repair: 'Reparación de cámaras y equipos',
      sensor: 'Limpieza de sensor',
      onSite: 'Servicio On-Site',
      productions: 'Producciones foto y video',
      membership: 'Membresía anual',
      company: 'Compañía',
      allServices: 'Todos los servicios',
      store: 'Tienda online',
      about: 'Sobre nosotros',
      faqs: 'Preguntas frecuentes',
      contact: 'Contacto',
      follow: 'Síguenos',
      rights: 'Todos los derechos reservados.',
      privacy: 'Privacidad',
      terms: 'Términos',
    }
  : {
      services: 'Services',
      repair: 'Camera & Gear Repair',
      sensor: 'Sensor Cleaning',
      onSite: 'On-Site Service',
      productions: 'Photo & Video Productions',
      membership: 'Annual Membership',
      company: 'Company',
      allServices: 'All Services',
      store: 'Online Store',
      about: 'About Us',
      faqs: 'FAQs',
      contact: 'Contact',
      follow: 'Follow',
      rights: 'All rights reserved.',
      privacy: 'Privacy',
      terms: 'Terms',
    };
const p = (path: string) => localePath(locale, path);
const year = new Date().getFullYear();
---
<footer id="contact" class="footer" aria-label="Site footer">
  <div class="footer__inner">
    <div class="footer__col footer__col--brand">
      <p class="footer__brand">Miami Photography Center</p>
      <p class="footer__address">3911 SW 27th St<br/>West Park, FL 33023<br/>United States</p>
      <p class="footer__contact">
        <a href="tel:+17867632091">+1 (786) 763-2091</a><br/>
        <a href="mailto:service@miamiphotographycenter.com">service@miamiphotographycenter.com</a>
      </p>
    </div>
    <div class="footer__col">
      <p class="footer__heading">{t.services}</p>
      <ul>
        <li><a href={p('/repair')}>{t.repair}</a></li>
        <li><a href={p('/sensor-cleaning')}>{t.sensor}</a></li>
        <li><a href={p('/on-site')}>{t.onSite}</a></li>
        <li><a href={p('/membership')}>{t.membership}</a></li>
        <li><a href={p('/productions')}>{t.productions}</a></li>
      </ul>
    </div>
    <div class="footer__col">
      <p class="footer__heading">{t.company}</p>
      <ul>
        <li><a href={p('/services')}>{t.allServices}</a></li>
        <li><a href={p('/store')}>{t.store}</a></li>
        <li><a href={p('/about')}>{t.about}</a></li>
        <li><a href={p('/faq')}>{t.faqs}</a></li>
        <li><a href={p('/contact')}>{t.contact}</a></li>
      </ul>
    </div>
    <div class="footer__col">
      <p class="footer__heading">{t.follow}</p>
      <ul>
        <li><a href="https://www.instagram.com/miamiphotographycenter" rel="noopener">Instagram</a></li>
        <li><a href="https://www.facebook.com/miamiphotographycenter" rel="noopener">Facebook</a></li>
        <li><a href="https://www.tiktok.com/@miamiphotographycenter" rel="noopener">TikTok</a></li>
      </ul>
    </div>
  </div>
  <div class="footer__bottom">
    <p>&copy; {year} Miami Photography Center. {t.rights}</p>
    <ul>
      <li><a href={p('/privacy')}>{t.privacy}</a></li>
      <li><a href={p('/terms')}>{t.terms}</a></li>
    </ul>
  </div>
</footer>
