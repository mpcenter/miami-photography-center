  description: 'Servicio móvil de cámaras en el sur de Florida. Limpieza de sensor en 30 minutos, diagnóstico in situ, recogida y entrega de equipos, soporte en eventos y planes de mantenimiento a medida, donde estés.',
  breadcrumbHome: 'Inicio',
  breadcrumbServices: 'Servicios',
  breadcrumbCurrent: 'Mantenimiento',
  heroEyebrow: 'Servicio móvil · Sur de Florida',
  heroTitle: 'Mantenimiento',
  heroSub: 'Llevamos el taller a tu locación',
  heroLede: 'Más que una van: un laboratorio de servicio completo sobre ruedas. Vamos a tu locación para limpieza, diagnóstico y reparaciones expertas. O recogemos tu equipo, lo atendemos en nuestro centro técnico y te lo devolvemos listo para disparar.',
  heroCta1: 'Agendar visita in situ',
  heroCta2: 'Ver cobertura',
  offersEyebrow: 'Qué hacemos in situ',
  offersTitle: 'Cinco maneras de llevarte el taller.',
  offers: [
    {
      featured: true,
      tag: 'El más solicitado · 30 minutos',
      title: 'Limpieza Profesional de Sensor In Situ',
      tagline: 'Nuestro servicio más solicitado. Equipo completo limpio en solo 30 minutos. Cada visita incluye:',
      bullets: [
        'Limpieza húmeda del sensor con técnicas profesionales',
        'Limpieza externa del cuerpo de la cámara',
        'Limpieza de un lente y un accesorio adicional (flash, grip, etc.)',
        'Mantenimiento preventivo del equipo completo: cámara + lente + accesorio',
        'Inspección de botones, contactos, monturas y puntos de conexión',
        'Lubricación de partes externas móviles',
        'Actualización de firmware gratis (si aplica)',
      ],
      note: 'Tiempo estimado: 30 minutos. Puede aplicar una pequeña tarifa de traslado según tu zona.',
      link: '', linkLabel: '',
    },
    {
      featured: false,
      tag: 'Diagnóstico',
      title: 'Diagnóstico In Situ y Recogida de Equipos',
      tagline: 'Detectamos el problema y lo resolvemos sin que tengas que trasladarte.',
      bullets: [
        'Diagnóstico in situ y presupuestos de reparación',
        'Recogida de equipos que requieren reparación de taller',
        'Entrega de retorno una vez completada la reparación',
      ],
      note: 'Nota: si el diagnóstico implica desarme o evaluación avanzada, puede aplicar una tarifa técnica. Siempre te avisamos antes, sin sorpresas.',
      link: '', linkLabel: '',
    },
    {
      featured: false,
      tag: 'Eventos',
      title: 'Eventos, Conferencias y Encuentros de Fotógrafos',
      tagline: 'Soporte técnico en vivo, donde esté la acción.',
      bullets: [
        'Asistimos a eventos de foto y video con nuestras unidades móviles',
        'Recibimos equipos en el lugar para limpieza de sensor y mantenimiento',
        'Diagnóstico gratuito y soporte técnico inmediato',
        'Disponible en toda Florida (mínimo de 20 equipos por evento)',
      ],
      note: '',
      link: '', linkLabel: '',
    },
    {
      featured: false,
      tag: 'Logística',
      title: 'Recogida y Entrega para Reparaciones Avanzadas',
      tagline: 'Si tu equipo necesita trabajo de laboratorio, igual te lo hacemos fácil.',
      bullets: [
        'Recogemos tu equipo en tu locación',
        'Realizamos la reparación en nuestras instalaciones especializadas',
        'Lo devolvemos por correo o en la próxima visita programada',
      ],
      note: '',
      link: '', linkLabel: '',
    },
    {
      featured: false,
      tag: 'Planes recurrentes',
      title: 'Planes de Mantenimiento a Medida',
      tagline: 'Diseñados para fotógrafos, estudios, escuelas y productoras. Planes recurrentes o personalizados que incluyen:',
      bullets: [
        'Servicios de mantenimiento por lotes',
        'Visitas in situ programadas',
        'Soporte técnico directo',
        'Descuentos por volumen',
        'Reportes detallados del estado de los equipos',
      ],
      note: '',
      link: '/membership', linkLabel: 'Ver planes de membresía',
    },
  ],
  howEyebrow: 'Cómo funciona',
  howTitle: 'Cuatro pasos.<br/>Cero tiempo muerto.',
  steps: [
    { num: '01', title: 'Agenda', copy: 'Reserva fecha, hora y locación. Cuéntanos qué equipo y qué servicio. Confirmamos en un día hábil.' },
    { num: '02', title: 'Llegamos', copy: 'A tiempo, totalmente equipados. Estación de limpieza calibrada, flujo antiestático, cada herramienta de nuestro taller.' },
    { num: '03', title: 'Servicio en el lugar', copy: 'La mayoría de los trabajos mientras observas. Limpieza de sensor, calibración de lentes, firmware y diagnóstico. Normalmente de 20 a 60 minutos por cámara.' },
    { num: '04', title: 'De vuelta al trabajo', copy: 'Equipo listo, sin tiempo muerto, todo documentado. Las reparaciones mayores que requieren repuestos van a nuestro taller con fecha de retorno.' },
  ],
  zonesEyebrow: 'Zonas de cobertura',
  zonesTitle: 'Cuatro condados.<br/>Un taller sobre ruedas.',
  zones: [
    { county: 'Miami-Dade', cities: 'Miami · Miami Beach · Coral Gables · Doral · Aventura · Homestead · Kendall', fee: 'Traslado desde <strong>$25</strong>' },
    { county: 'Broward', cities: 'Fort Lauderdale · Hollywood · Pembroke Pines · Pompano · West Park · Plantation', fee: 'Traslado desde <strong>$25</strong>' },
    { county: 'Palm Beach', cities: 'West Palm Beach · Boca Raton · Delray Beach · Boynton · Jupiter · Wellington', fee: 'Traslado desde <strong>$50</strong>' },
    { county: 'Monroe / Cayos de Florida', cities: 'Key Largo · Islamorada · Marathon · Big Pine · Key West', fee: 'Traslado <strong>por cotización</strong>' },
  ],
  pricingEyebrow: 'Precios in situ',
  pricingTitle: 'Tarifas transparentes.<br/>Cotizamos antes de movernos.',
  pricingSub: 'Tarifa de servicio + traslado por zona. Descuentos por varias cámaras y por volumen disponibles. Sets y emergencias tienen despacho prioritario.',
  prices: [
    { label: 'Limpieza de sensor in situ', from: 'Desde', price: '$79', note: 'Por cámara. Garantía de re-limpieza de 30 días.', accent: false },
    { label: 'Calibración in situ', from: 'Desde', price: '$99', note: 'Microajuste de AF, precisión de enfoque, ColorChecker.', accent: false },
    { label: 'Día de producción', from: 'Desde', price: '$299', note: 'Hasta 8 horas en set. Multicámara. Prioridad.', accent: true },
    { label: 'Tarifas de traslado', from: 'Desde', price: '$25', note: 'Miami-Dade y Broward. PB +$50. Cayos por cotización.', accent: false },
  ],
  bookingEyebrow: 'Agenda una visita',
  bookingTitle: 'Dinos dónde, cuándo y qué.',
  bookingSub: 'Confirmamos en un día hábil con un presupuesto por escrito.',
  formSuccess: 'Solicitud recibida. Confirmaremos tu visita en un día hábil.',
  fName: 'Nombre completo *',
  fNamePh: '¿Cómo te llamas?',
  fService: 'Tipo de servicio',
  fServiceOptions: ['Selecciona un servicio', 'Limpieza de sensor in situ', 'Diagnóstico y recogida', 'Soporte en evento o encuentro', 'Recogida y entrega para reparación', 'Plan de mantenimiento a medida', 'Otro'],
  fAddress: 'Dirección / zona *',
  fAddressPh: 'p. ej. Miami Beach, FL',
  fPhone: 'Teléfono *',
  fPhonePh: '(786) 555-0100',
  fEmail: 'Email *',
  fEmailPh: 'tu@email.com',
  fDate: 'Fecha preferida',
  fCount: 'Cantidad de equipos *',
  fCountPh: 'p. ej. 2',
  submit: 'Solicitar visita in situ',
  legalPre: 'Al enviar aceptas nuestra ',
  legalLink: 'política de privacidad',
  legalPost: '. Nunca compartimos tus datos.',
  faqEyebrow: 'Preguntas frecuentes',
  faqTitle: 'Dudas sobre el servicio in situ.',
  faq: [
    { q: '¿Qué incluye el servicio in situ?', a: 'Limpieza de sensor, calibración de lentes, pruebas de enfoque, ajustes mecánicos menores, actualizaciones de firmware y diagnóstico completo. Las reparaciones complejas que requieren repuestos van a nuestro taller.' },
    { q: '¿Qué tan rápido pueden llegar?', a: 'El mismo día para emergencias en Miami-Dade y Broward cuando hay disponibilidad. Citas estándar entre 24 y 72 horas en el sur de Florida. Los sets de producción y las bodas tienen despacho prioritario.' },
    { q: '¿Qué zonas cubren?', a: 'Los condados Miami-Dade, Broward, Palm Beach y Monroe, de West Palm Beach a Key West. Las tarifas de traslado varían por zona.' },
    { q: '¿Pueden dar servicio en un set de filmación?', a: 'Sí. Trabajamos alrededor de tu call sheet. Montaje discreto, flujo antiestático y nos movemos con tu producción. La limpieza de sensor suele hacerse entre tomas.' },
    { q: '¿Cuánto cuesta?', a: 'La tarifa de servicio empieza en $79 más traslado por zona. Miami-Dade y Broward desde $25, Palm Beach $50, Cayos de Florida por cotización. Descuentos por varias cámaras y por volumen disponibles.' },
    { q: '¿Traen sus propias herramientas?', a: 'Sí. Estación de limpieza calibrada, equipo antiestático, hisopos de sensor en todos los tamaños, peras de aire, lupas de sensor, cartas de calibración de lentes, ColorChecker y kit de diagnóstico. Todo lo que encontrarías en nuestro taller, portátil.' },
  ],
  ctaTitle: 'Ya estamos en camino.',
  ctaCopy: 'Dinos dónde encontrarte. Confirmamos en un día hábil.',
  ctaBtn1: 'Agendar visita in situ',
  ctaBtn2: 'Llamar (786) 763-2091',
} : {
  title: 'Camera Maintenance Miami | Mobile Sensor Cleaning & Repair — MPC',
  description: 'Mobile camera service across South Florida. Sensor cleaning in 30 minutes, on-site diagnostics, equipment pickup & delivery, event support, and custom maintenance plans — wherever you are.',
  breadcrumbHome: 'Home',
  breadcrumbServices: 'Services',
  breadcrumbCurrent: 'Maintenance',
  heroEyebrow: 'Mobile Service · South Florida',
  heroTitle: 'Maintenance',
  heroSub: 'We bring the workshop to you',
  heroLede: 'More than just a van — a full-service lab on wheels. We come to your location for cleaning, diagnostics, and expert repairs. Or we pick up your gear, service it at our technical center, and deliver it back ready to shoot.',
  heroCta1: 'Book an on-site visit',
  heroCta2: 'See coverage',
  offersEyebrow: 'What we do on-site',
  offersTitle: 'Five ways we bring the workshop to you.',
  offers: [
    {
      featured: true,
      tag: 'Most requested · 30 minutes',
      title: 'Professional Sensor Cleaning On-Site',
      tagline: 'Our most requested service. Full setup cleaned in just 30 minutes. Each visit includes:',
      bullets: [
        'Wet sensor cleaning using professional techniques',
        'External cleaning of the camera body',
        'Cleaning of one lens and one additional accessory (flash, grip, etc.)',
        'Preventive maintenance for the full setup: camera + lens + accessory',
        'Inspection of buttons, contacts, mounts, and connection points',
        'Lubrication of moving external parts',
        'Free firmware update (if applicable)',
      ],
      note: 'Estimated time: 30 minutes. A small travel fee may apply depending on your area.',
      link: '', linkLabel: '',
    },
    {
      featured: false,
      tag: 'Diagnostics',
      title: 'On-Site Diagnostics & Equipment Pickup',
      tagline: 'We detect the problem and fix it — no need to travel.',
      bullets: [
        'On-site diagnostics and repair estimates',
        'Pickup of equipment that requires workshop-level repair',
        'Return delivery once repairs are completed',
      ],
      note: 'Note: If the diagnosis involves disassembly or advanced evaluation, a technical fee may apply. We always inform you beforehand — no surprises.',
      link: '', linkLabel: '',
    },
    {
      featured: false,
      tag: 'Events',
      title: 'Events, Conferences & Photographer Meetups',
      tagline: 'Live tech support, wherever the action is.',
      bullets: [
        'We attend photography and video events with our mobile units',
        'Receive gear on-site for sensor cleaning and maintenance',
        'Provide free diagnostics and immediate technical support',
        'Available throughout Florida (minimum of 20 items required per event)',
      ],
      note: '',
      link: '', linkLabel: '',
    },
    {
      featured: false,
      tag: 'Logistics',
      title: 'Pickup & Delivery for Advanced Repairs',
      tagline: 'If your gear needs lab work, we still make it easy.',
      bullets: [
        'We pick up your gear from your location',
        'Perform the repair in our specialized facility',
        'Return it via mail or at the next scheduled visit',
      ],
      note: '',
      link: '', linkLabel: '',
    },
    {
      featured: false,
      tag: 'Recurring plans',
      title: 'Custom Maintenance Plans',
      tagline: 'Designed for photographers, studios, schools, and production companies. Recurring or personalized plans that include:',
      bullets: [
        'Batch maintenance services',
        'Scheduled on-site visits',
        'Direct technical support',
        'Volume discounts',
        'Detailed reports on equipment condition',
      ],
      note: '',
      link: '/membership', linkLabel: 'See membership plans',
    },
  ],
  howEyebrow: 'How it works',
  howTitle: 'Four steps.<br/>Zero downtime.',
  steps: [
    { num: '01', title: 'Schedule', copy: 'Book a date, time, and location. Tell us what gear and what service. We confirm within one business day.' },
    { num: '02', title: 'We arrive', copy: 'On time, fully equipped. Calibrated cleaning station, anti-static workflow, every tool you’d find in our workshop.' },
    { num: '03', title: 'Service on-site', copy: 'Most jobs done while you watch. Sensor clean, lens calibration, firmware, diagnostic — typically 20 to 60 minutes per camera.' },
    { num: '04', title: 'Back to work', copy: 'Gear ready, no downtime, fully documented. Major repairs that require parts come back to our workshop with a return-by date.' },
  ],
  zonesEyebrow: 'Coverage zones',
  zonesTitle: 'Four counties.<br/>One workshop on wheels.',
  zones: [
    { county: 'Miami-Dade', cities: 'Miami · Miami Beach · Coral Gables · Doral · Aventura · Homestead · Kendall', fee: 'Travel from <strong>$25</strong>' },
    { county: 'Broward', cities: 'Fort Lauderdale · Hollywood · Pembroke Pines · Pompano · West Park · Plantation', fee: 'Travel from <strong>$25</strong>' },
    { county: 'Palm Beach', cities: 'West Palm Beach · Boca Raton · Delray Beach · Boynton · Jupiter · Wellington', fee: 'Travel from <strong>$50</strong>' },
    { county: 'Monroe / Florida Keys', cities: 'Key Largo · Islamorada · Marathon · Big Pine · Key West', fee: 'Travel <strong>by quote</strong>' },
  ],
  pricingEyebrow: 'On-site pricing',
  pricingTitle: 'Transparent rates.<br/>Quote before we move.',
  pricingSub: 'Service fee + travel by zone. Multiple cameras and bulk discounts available. Sets and emergencies get priority dispatch.',
  prices: [
    { label: 'On-site sensor clean', from: 'From', price: '$79', note: 'Per camera. 30-day re-clean guarantee.', accent: false },
    { label: 'On-site calibration', from: 'From', price: '$99', note: 'AF micro-adjust, focus accuracy, ColorChecker.', accent: false },
    { label: 'Production day rate', from: 'From', price: '$299', note: 'Up to 8 hours on set. Multi-camera. Priority.', accent: true },
    { label: 'Travel fees', from: 'From', price: '$25', note: 'Miami-Dade & Broward. PB +$50. Keys by quote.', accent: false },
  ],
  bookingEyebrow: 'Schedule a visit',
  bookingTitle: 'Tell us where, when, and what.',
  bookingSub: 'We confirm within one business day with a written quote.',
  formSuccess: 'Request received. We will confirm your visit within one business day.',
  fName: 'Full name *',
  fNamePh: 'Your name',
  fService: 'Service type',
  fServiceOptions: ['Select a service', 'Sensor cleaning on-site', 'Diagnostics & equipment pickup', 'Event or meetup support', 'Pickup & delivery for repairs', 'Custom maintenance plan', 'Other'],
  fAddress: 'Address / area *',
  fAddressPh: 'e.g. Miami Beach, FL',
  fPhone: 'Phone *',
  fPhonePh: '(786) 555-0100',
  fEmail: 'Email *',
  fEmailPh: 'you@example.com',
  fDate: 'Preferred date',
  fCount: 'Equipment count *',
  fCountPh: 'e.g. 2',
  submit: 'Request on-site visit',
  legalPre: 'By submitting you agree to our ',
  legalLink: 'privacy policy',
  legalPost: '. We never share your data.',
  faqEyebrow: 'FAQ',
  faqTitle: 'On-site questions.',
  faq: [
    { q: 'What does on-site service include?', a: 'Sensor cleaning, lens calibration, focus testing, minor mechanical adjustments, firmware updates, and full diagnostic. Complex repairs requiring parts come back to our workshop.' },
    { q: 'How fast can you arrive?', a: 'Same-day for emergencies in Miami-Dade and Broward when slots are available. Standard appointments within 24 to 72 hours across South Florida. Production sets and weddings get priority dispatch.' },
    { q: 'Where do you cover?', a: 'Miami-Dade, Broward, Palm Beach, and Monroe counties — from West Palm Beach to Key West. Travel fees vary by zone.' },
    { q: 'Can you service on a film set?', a: 'Yes. We work around your call sheet. Discreet setup, anti-static workflow, and we move with your production. Sensor cleaning typically done between takes.' },
    { q: 'What does it cost?', a: 'Service fee starts at $79 plus travel by zone. Miami-Dade and Broward zones from $25, Palm Beach $50, Florida Keys custom. Multiple cameras and bulk discounts available.' },
    { q: 'Do you bring your own tools?', a: 'Yes. Calibrated cleaning station, anti-static gear, sensor swabs in every size, air blowers, sensor loupes, lens calibration charts, ColorChecker, and diagnostic toolkit. Everything you’d find at our workshop, portable.' },
  ],
  ctaTitle: 'Already on the way.',
  ctaCopy: 'Tell us where to meet you. We confirm within one business day.',
  ctaBtn1: 'Book an on-site visit',
  ctaBtn2: 'Call (786) 763-2091',
};

const origin = 'https://miamiphotographycenter.com';

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.breadcrumbHome, item: origin + p('/') },
    { '@type': 'ListItem', position: 2, name: t.breadcrumbServices, item: origin + p('/services') },
    { '@type': 'ListItem', position: 3, name: t.breadcrumbCurrent, item: origin + p('/on-site') },
  ],
});

const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': origin + p('/on-site') + '#service',
  serviceType: 'Mobile Camera Service',
  name: 'On-Site Camera & Sensor Service',
  description: 'Mobile camera service: sensor cleaning, calibration, and minor repairs delivered at your studio, set, or location across South Florida.',
  provider: { '@type': 'LocalBusiness', '@id': 'https://miamiphotographycenter.com/#localbusiness' },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Miami-Dade County' },
    { '@type': 'AdministrativeArea', name: 'Broward County' },
    { '@type': 'AdministrativeArea', name: 'Palm Beach County' },
    { '@type': 'AdministrativeArea', name: 'Monroe County' },
  ],
  offers: { '@type': 'AggregateOffer', lowPrice: '79', highPrice: '299', priceCurrency: 'USD' },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
});
---
<Base locale={locale} title={t.title} description={t.description}>
  <script type="application/ld+json" set:html={breadcrumbSchema} slot="head" is:inline />
  <script type="application/ld+json" set:html={serviceSchema} slot="head" is:inline />
  <script type="application/ld+json" set:html={faqSchema} slot="head" is:inline />
  <script src="/scripts/on-site.js" defer is:inline slot="head"></script>

  <!-- ==================== HERO (SVG map of South Florida) ==================== -->
  <header class="hero hero--onsite">
    <div class="hero__ring" aria-hidden="true"></div>

    <div class="hero__container hero__container--split">
      <div class="hero__text">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <ol>
            <li><a href={p('/')}>{t.breadcrumbHome}</a></li>
            <li><a href={p('/services')}>{t.breadcrumbServices}</a></li>
            <li aria-current="page">{t.breadcrumbCurrent}</li>
          </ol>
        </nav>

        <p class="hero__eyebrow" data-anim="fade-up">{t.heroEyebrow}</p>
        <h1 class="hero__title" data-anim="hero-title">{t.heroTitle}</h1>
        <p class="hero__sub" data-anim="fade-up">{t.heroSub}</p>
        <p class="hero__lede" data-anim="fade-up">{t.heroLede}</p>
        <div class="hero__ctas" data-anim="fade-up">
          <a href="#booking-form" class="btn btn--primary">{t.heroCta1}</a>
          <a href="#coverage" class="btn btn--ghost">{t.heroCta2} <span aria-hidden="true">→</span></a>
        </div>
      </div>

      <!-- Inline SVG: stylized South Florida map with animated pins + route -->
      <div class="hero__map" data-map aria-hidden="true">
        <svg viewBox="0 0 600 700" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Map of South Florida service coverage area">
          <defs>
            <linearGradient id="landGrad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#2a2a2c"/>
              <stop offset="100%" stop-color="#0e0e10"/>
            </linearGradient>
            <radialGradient id="pinGlow" cx="0.5" cy="0.5" r="0.5">
              <stop offset="0%" stop-color="#ffff00" stop-opacity="0.55"/>
              <stop offset="100%" stop-color="#ffff00" stop-opacity="0"/>
            </radialGradient>
            <linearGradient id="routeGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#ffff00"/>
              <stop offset="100%" stop-color="#ffff00"/>
            </linearGradient>
          </defs>

          <g opacity="0.18">
            <circle cx="400" cy="100" r="1.5" fill="#86868b"/>
            <circle cx="450" cy="180" r="1.5" fill="#86868b"/>
            <circle cx="480" cy="260" r="1.5" fill="#86868b"/>
            <circle cx="500" cy="350" r="1.5" fill="#86868b"/>
            <circle cx="490" cy="440" r="1.5" fill="#86868b"/>
            <circle cx="460" cy="520" r="1.5" fill="#86868b"/>
            <circle cx="420" cy="600" r="1.5" fill="#86868b"/>
            <circle cx="370" cy="650" r="1.5" fill="#86868b"/>
            <circle cx="350" cy="120" r="1.5" fill="#86868b"/>
            <circle cx="380" cy="220" r="1.5" fill="#86868b"/>
            <circle cx="420" cy="300" r="1.5" fill="#86868b"/>
            <circle cx="440" cy="400" r="1.5" fill="#86868b"/>
            <circle cx="430" cy="480" r="1.5" fill="#86868b"/>
            <circle cx="400" cy="560" r="1.5" fill="#86868b"/>
            <circle cx="320" cy="640" r="1.5" fill="#86868b"/>
          </g>

          <!-- South Florida peninsula — tapering east coast with Cape Canaveral bump,
               Gulf-coast curves (Charlotte Harbor / Tampa Bay), point at the south -->
          <path d="
            M 140 65
            L 350 65
            Q 357 115 356 160
            Q 359 205 348 248
            Q 342 292 328 332
            Q 314 376 299 416
            Q 286 456 268 496
            Q 252 542 240 582
            Q 233 600 224 606
            Q 206 596 193 576
            Q 179 556 173 531
            Q 166 501 176 471
            Q 183 449 166 433
            Q 151 416 159 389
            Q 166 361 151 341
            Q 139 319 146 291
            Q 153 256 141 221
            Q 131 181 133 141
            Q 135 101 140 65 Z
          " fill="url(#landGrad)" stroke="#3a3a3d" stroke-width="1"/>

          <!-- Florida Keys — island chain trailing southwest from the tip -->
          <g class="map-keys">
            <ellipse cx="212" cy="616" rx="13" ry="5" fill="url(#landGrad)" stroke="#3a3a3d" stroke-width="1"/>
            <ellipse cx="194" cy="628" rx="11" ry="4.5" fill="url(#landGrad)" stroke="#3a3a3d" stroke-width="1"/>
            <ellipse cx="178" cy="639" rx="10" ry="4" fill="url(#landGrad)" stroke="#3a3a3d" stroke-width="1"/>
            <ellipse cx="164" cy="649" rx="8.5" ry="3.7" fill="url(#landGrad)" stroke="#3a3a3d" stroke-width="1"/>
            <ellipse cx="152" cy="658" rx="7" ry="3.2" fill="url(#landGrad)" stroke="#3a3a3d" stroke-width="1"/>
          </g>

          <path
            id="serviceRoute"
            d="M 280 120 Q 270 240 255 340 Q 244 430 236 520 Q 230 572 222 598 Q 210 624 186 640 Q 170 650 156 658"
            fill="none"
            stroke="url(#routeGrad)"
            stroke-width="3"
            stroke-linecap="round"
            stroke-dasharray="6 6"
            opacity="0.85"
            class="map-route"
          />

          <g class="map-pin" data-pin="1" data-label="West Palm Beach">
            <circle cx="280" cy="120" r="32" fill="url(#pinGlow)"/>
            <circle cx="280" cy="120" r="10" fill="#ffff00"/>
            <circle cx="280" cy="120" r="4" fill="#ffffff"/>
            <text x="305" y="125" fill="#f5f5f7" font-family="Poppins, system-ui" font-size="14" font-weight="600">West Palm Beach</text>
          </g>

          <g class="map-pin" data-pin="5" data-label="The Keys">
            <circle cx="152" cy="658" r="26" fill="url(#pinGlow)"/>
            <circle cx="152" cy="658" r="8" fill="#ffff00"/>
            <circle cx="152" cy="658" r="3" fill="#ffffff"/>
            <text x="152" y="688" fill="#1d1d1f" text-anchor="middle" font-family="Poppins, system-ui" font-size="13" font-weight="600">The Keys</text>
          </g>

          <!-- Service van — Mercedes-Benz Sprinter (high-roof) side profile, facing right -->
          <g class="map-van" transform="translate(244, 432)">
            <ellipse cx="0" cy="11" rx="26" ry="3" fill="#000000" opacity="0.25"/>
            <path d="M -26 7 L -26 -15 Q -26 -16 -25 -16 L 9 -16 Q 12.5 -16 14.5 -12.5 L 20 -4 L 25 -3 Q 28 -2 28 2 L 28 6 Q 28 8 26 8 L -24 8 Q -26 8 -26 7 Z"
                  fill="#1d1d1f" stroke="#ffff00" stroke-width="1.5" stroke-linejoin="round"/>
            <rect x="-22" y="-13" width="19" height="8" rx="1" fill="#ffff00" opacity="0.55"/>
            <path d="M 1 -13 L 12 -13 Q 13.5 -13 15 -10 L 19 -4 L 1 -4 Z" fill="#ffff00" opacity="0.35"/>
            <circle cx="-15" cy="8" r="4.5" fill="#0e0e10" stroke="#ffff00" stroke-width="1.2"/>
            <circle cx="16" cy="8" r="4.5" fill="#0e0e10" stroke="#ffff00" stroke-width="1.2"/>
            <circle cx="-15" cy="8" r="1.6" fill="#ffff00"/>
            <circle cx="16" cy="8" r="1.6" fill="#ffff00"/>
            <rect x="25.5" y="0" width="2.5" height="2.5" rx="0.8" fill="#ffff00"/>
          </g>
        </svg>
      </div>
    </div>
  </header>

  <!-- ==================== OFFERINGS — 5 on-site services ==================== -->
  <section id="offerings" class="offers" aria-labelledby="offers-title">
    <div class="offers__head">
      <p class="eyebrow">{t.offersEyebrow}</p>
      <h2 id="offers-title" class="offers__title">{t.offersTitle}</h2>
    </div>

    <div class="offers__grid">
      {t.offers.map((offer) => (
        <article class={`offer${offer.featured ? ' offer--featured' : ''}`} data-anim="fade-up">
          <p class="offer__tag">{offer.tag}</p>
          <h3 class="offer__title">{offer.title}</h3>
          <p class="offer__tagline">{offer.tagline}</p>
          <ul class="offer__bullets">
            {offer.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
          {offer.note && <p class="offer__note">{offer.note}</p>}
          {offer.link && (
            <a href={p(offer.link)} class="offer__link">{offer.linkLabel} <span aria-hidden="true">→</span></a>
          )}
        </article>
      ))}
    </div>
  </section>

  <!-- ==================== HOW IT WORKS — 4 steps ==================== -->
  <section id="how" class="repair-process" aria-labelledby="how-title">
    <div class="repair-process__head">
      <p class="eyebrow">{t.howEyebrow}</p>
      <h2 id="how-title" class="repair-process__title" set:html={t.howTitle} />
    </div>

    <ol class="timeline timeline--4">
      {t.steps.map((step) => (
        <li class="timeline__item" data-anim="fade-up">
          <span class="timeline__dot"></span>
          <div class="timeline__card">
            <p class="timeline__num">{step.num}</p>
            <h3>{step.title}</h3>
            <p>{step.copy}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- ==================== COVERAGE — Counties ==================== -->
  <section id="coverage" class="coverage-zones" aria-labelledby="zones-title">
    <div class="coverage-zones__parallax"></div>
    <div class="coverage-zones__inner">
      <p class="eyebrow eyebrow--light">{t.zonesEyebrow}</p>
      <h2 id="zones-title" class="coverage-zones__title" set:html={t.zonesTitle} />

      <div class="zones__grid">
        {t.zones.map((zone) => (
          <article class="zone">
            <p class="zone__county">{zone.county}</p>
            <p class="zone__cities">{zone.cities}</p>
            <p class="zone__fee" set:html={zone.fee} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== PRICING ==================== -->
  <section class="pricing" aria-labelledby="onsite-pricing-title">
    <div class="pricing__head">
      <p class="eyebrow">{t.pricingEyebrow}</p>
      <h2 id="onsite-pricing-title" class="pricing__title" set:html={t.pricingTitle} />
      <p class="pricing__sub">{t.pricingSub}</p>
    </div>

    <div class="pricing__grid">
      {t.prices.map((card) => (
        <div class={`price-card${card.accent ? ' price-card--accent' : ''}`} data-anim="fade-up">
          <p class="price-card__label">{card.label}</p>
          <p class="price-card__price">{card.from} <span>{card.price}</span></p>
          <p class="price-card__note">{card.note}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ==================== BOOKING FORM ==================== -->
  <section id="schedule" class="booking" aria-labelledby="booking-title">
    <div class="booking__head">
      <p class="eyebrow">{t.bookingEyebrow}</p>
      <h2 id="booking-title" class="booking__title">{t.bookingTitle}</h2>
      <p class="booking__sub">{t.bookingSub}</p>
    </div>

    <form id="booking-form" class="form js-demo-form" action="#" method="POST" data-success={t.formSuccess}>
      <div class="form__row">
        <div class="form__field">
          <label for="bk-name">{t.fName}</label>
          <input id="bk-name" type="text" name="name" required autocomplete="name" placeholder={t.fNamePh} />
        </div>
        <div class="form__field">
          <label for="bk-service">{t.fService}</label>
          <select id="bk-service" name="service">
            {t.fServiceOptions.map((option, i) => (
              i === 0 ? <option value="">{option}</option> : <option>{option}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="form__row">
        <div class="form__field">
          <label for="bk-address">{t.fAddress}</label>
          <input id="bk-address" type="text" name="address" required autocomplete="street-address" placeholder={t.fAddressPh} />
        </div>
        <div class="form__field">
          <label for="bk-phone">{t.fPhone}</label>
          <input id="bk-phone" type="tel" name="phone" required autocomplete="tel" placeholder={t.fPhonePh} />
        </div>
      </div>

      <div class="form__row">
        <div class="form__field">
          <label for="bk-email">{t.fEmail}</label>
          <input id="bk-email" type="email" name="email" required autocomplete="email" placeholder={t.fEmailPh} />
        </div>
        <div class="form__field">
          <label for="bk-date">{t.fDate}</label>
          <input id="bk-date" type="date" name="date" />
        </div>
      </div>

      <div class="form__field">
        <label for="bk-count">{t.fCount}</label>
        <input id="bk-count" type="number" name="equipment_count" required min="1" inputmode="numeric" placeholder={t.fCountPh} />
      </div>

      <div class="booking__actions">
        <button type="submit" class="btn btn--primary btn--lg">{t.submit}</button>
        <p class="form__note">{t.legalPre}<a href={p('/privacy')}>{t.legalLink}</a>{t.legalPost}</p>
      </div>
    </form>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section id="faq" class="faq" aria-labelledby="faq-title">
    <div class="faq__head">
      <p class="eyebrow">{t.faqEyebrow}</p>
      <h2 id="faq-title" class="faq__title">{t.faqTitle}</h2>
    </div>

    <ul class="faq__list">
      {t.faq.map((item) => (
        <li class="faq__item">
          <details>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        </li>
      ))}
    </ul>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="cta" aria-labelledby="cta-title">
    <div class="cta__inner">
      <h2 id="cta-title" class="cta__title">{t.ctaTitle}</h2>
      <p class="cta__copy">{t.ctaCopy}</p>
      <div class="cta__actions">
        <a href="#booking-form" class="btn btn--primary btn--lg">{t.ctaBtn1}</a>
        <a href="tel:+17867632091" class="btn btn--ghost btn--lg">{t.ctaBtn2}</a>
      </div>
    </div>
  </section>
</Base>
