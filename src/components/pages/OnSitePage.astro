---
import Base from '../../layouts/Base.astro';
import { localePath, type Locale } from '../../lib/i18n';
import '../../styles/on-site.css';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const p = (path: string) => localePath(locale, path);

const t = locale === 'es' ? {
