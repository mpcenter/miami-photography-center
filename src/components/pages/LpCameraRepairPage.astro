---
import Base from '../../layouts/Base.astro';
import { type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const t = locale === 'es' ? {
  title: 'Reparación de Cámaras en Miami — en el Taller, Garantía de 6 Meses | MPC',
  description: 'Reparación profesional de cámaras en Miami. Diagnóstico gratis, repuestos originales y prueba completa, todo en el taller. Garantía de 6 meses en cada reparación.',
  heroEyebrow: 'Reparación de cámaras · Miami',
  heroTitle: '¿Cámara dañada? Reparada en el taller, garantizada por 6 meses.',
  heroSub: 'Técnicos senior, repuestos originales y herramientas de micro-calibración — la mayoría de las reparaciones en 7 a 15 días hábiles. Plan de diagnóstico gratis: presupuesto antes de cualquier trabajo.',
  heroCta: 'Solicitar mi reparación',
  badges: ['Garantía de 6 meses', '10+ años de experiencia', 'Canon · Nikon · Sony · Fujifilm'],
  stepsTitle: 'Así de simple.',
  steps: [
    { num: '01', title: 'Cuéntanos qué pasa', copy: 'Completa el formulario con marca, modelo y el problema. Fotos bienvenidas. Respondemos en un día hábil.' },
    { num: '02', title: 'Diagnóstico y presupuesto', copy: 'Plan de diagnóstico gratis y presupuesto claro antes de tocar tu equipo. Tú apruebas, nosotros trabajamos.' },
    { num: '03', title: 'Reparación y entrega', copy: 'Reparación en el taller, prueba completa y entrega o envío de retorno. La mayoría en 7–15 días hábiles.' },
  ],
  includesTitle: 'Qué incluye cada reparación.',
  includes: [
    'Diagnóstico completo del equipo antes de cualquier trabajo',
    'Repuestos originales y herramientas de micro-calibración',
    'Mantenimiento interno, limpieza de sensor y lubricación',
    'Actualización de firmware gratis (si aplica)',
    'Prueba completa de funcionamiento antes de la entrega',
    'Garantía de 6 meses en cada reparación',
  ],
  quotesTitle: 'Lo que dicen los fotógrafos.',
  quotes: [
    { quote: '“Repararon una Pentax vintage que dos talleres rechazaron. Quedó mejor que el día que la compré. Esta gente se preocupa.”', author: '— Luis R., Coleccionista' },
    { quote: '“Envié mi Sony A7IV desde Key West. Reparada, probada y devuelta en cinco días. Precio honesto, garantía real.”', author: '— Camila P., Editorial' },
    { quote: '“Limpieza de sensor in situ antes de una boda. Llegaron temprano, terminaron en veinte minutos y salvaron el día.”', author: '— Andrea M., Fotógrafa de bodas' },
  ],
  priceLabel: 'Precio',
  priceTitle: 'Plan de diagnóstico gratis — presupuesto antes de cualquier trabajo.',
  priceCopy: 'Nunca trabajamos sin tu aprobación. Recibes un diagnóstico claro y un presupuesto cerrado primero; tú decides si avanzamos. Sin cargos ocultos.',
  priceCta: 'Solicitar diagnóstico',
  formTitle: 'Solicita tu reparación.',
  formCopy: 'Respondemos en un día hábil con tu plan de diagnóstico.',
  formSuccess: 'Solicitud recibida. Te contactamos en un día hábil con tu plan de diagnóstico.',
  fName: 'Nombre completo',
  fPhone: 'Teléfono',
  fEmail: 'Email',
  fCamera: 'Modelo de cámara',
  fCameraPh: 'Ej. Canon EOS R6',
  fArea: 'Zona / Código postal',
  fAreaPh: 'Ej. Brickell, 33131',
  fContact: 'Método de contacto preferido',
  fContactOptions: ['Llamada', 'Mensaje de texto', 'WhatsApp', 'Email'],
  fSubmit: 'Solicitar mi reparación →',
  fNote: 'Demo de lanzamiento — el envío en línea se activa pronto. Mientras tanto, también puedes llamarnos.',
  finalTitle: '¿Prefieres hablar con un técnico?',
  finalCopy: 'Llámanos y cuéntanos qué le pasa a tu cámara hoy mismo.',
  finalCta: 'Llamar (786) 763-2091',
} : {
  title: 'Camera Repair Miami — In-House, 6-Month Warranty | MPC',
  description: 'Professional camera repair in Miami. Free diagnostic plan, original parts, and full testing — all in-house. 6-month warranty on every repair.',
  heroEyebrow: 'Camera Repair · Miami',
  heroTitle: 'Broken camera? Fixed in-house, guaranteed 6 months.',
  heroSub: 'Senior technicians, original parts, and micro-calibration tools — most repairs done in 7 to 15 business days. Free diagnostic plan: you get a quote before any work begins.',
  heroCta: 'Request my repair',
  badges: ['6-month warranty', '10+ years of experience', 'Canon · Nikon · Sony · Fujifilm'],
  stepsTitle: 'This simple.',
  steps: [
    { num: '01', title: 'Tell us what’s wrong', copy: 'Fill out the form with brand, model, and the issue. Photos welcome. We respond within one business day.' },
    { num: '02', title: 'Diagnostic & quote', copy: 'Free diagnostic plan and a clear quote before we touch your gear. You approve, we work.' },
    { num: '03', title: 'Repair & return', copy: 'In-house repair, full testing, and pickup or return shipping. Most jobs done in 7–15 business days.' },
  ],
  includesTitle: 'What every repair includes.',
  includes: [
    'Full equipment diagnostics before any work',
    'Original parts and micro-calibration tools',
    'Internal maintenance, sensor cleaning, and lubrication',
    'Free firmware update (if applicable)',
    'Full functional testing before handoff',
    '6-month warranty on every repair',
  ],
  quotesTitle: 'What photographers say.',
  quotes: [
    { quote: '“Fixed a vintage Pentax that two other shops refused. Better than the day I bought it. These people care.”', author: '— Luis R., Film Collector' },
    { quote: '“Sent my Sony A7IV from Key West. Repaired, tested, returned in five days. Honest pricing, real warranty.”', author: '— Camila P., Editorial' },
    { quote: '“On-site sensor clean before a wedding shoot. They arrived early, finished in twenty minutes, and saved the day.”', author: '— Andrea M., Wedding Photographer' },
  ],
  priceLabel: 'Pricing',
  priceTitle: 'Free diagnostic plan — quote before any work.',
  priceCopy: 'We never start without your approval. You get a clear diagnostic and a fixed quote first; you decide if we move forward. No hidden fees.',
  priceCta: 'Get my free diagnostic plan',
  formTitle: 'Request your repair.',
  formCopy: 'We respond within one business day with your diagnostic plan.',
  formSuccess: 'Request received. We will contact you within one business day with your diagnostic plan.',
  fName: 'Full name',
  fPhone: 'Phone',
  fEmail: 'Email',
  fCamera: 'Camera model',
  fCameraPh: 'e.g. Canon EOS R6',
  fArea: 'Area / ZIP code',
  fAreaPh: 'e.g. Brickell, 33131',
  fContact: 'Preferred contact method',
  fContactOptions: ['Phone call', 'Text message', 'WhatsApp', 'Email'],
  fSubmit: 'Request my repair →',
  fNote: 'Launch demo — online submission activates soon. In the meantime, you can also call us.',
  finalTitle: 'Rather talk to a technician?',
  finalCopy: 'Call us and tell us what’s wrong with your camera today.',
  finalCta: 'Call (786) 763-2091',
};
---
<Base locale={locale} title={t.title} description={t.description} minimal={true}>
  <!-- ==================== LP HERO ==================== -->
  <header class="lp-hero">
    <div class="lp-hero__inner">
      <p class="eyebrow" data-anim="fade-up">{t.heroEyebrow}</p>
      <h1 class="lp-hero__title" data-anim="fade-up">{t.heroTitle}</h1>
      <p class="lp-hero__sub" data-anim="fade-up">{t.heroSub}</p>
      <div class="lp-hero__cta" data-anim="fade-up">
        <a href="#lp-form" class="btn btn--primary btn--lg">{t.heroCta} <span aria-hidden="true">→</span></a>
      </div>
      <ul class="lp-badges" data-anim="fade-up">
        {t.badges.map((badge) => <li>{badge}</li>)}
      </ul>
    </div>
  </header>

  <!-- ==================== 3 STEPS ==================== -->
  <section class="lp-steps" aria-labelledby="lp-steps-title">
    <div class="lp-section__inner">
      <h2 id="lp-steps-title" class="lp-section__title">{t.stepsTitle}</h2>
      <ol class="lp-steps__grid">
        {t.steps.map((step) => (
          <li class="lp-steps__step" data-anim="fade-up">
            <span class="lp-steps__num">{step.num}</span>
            <h3>{step.title}</h3>
            <p>{step.copy}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ==================== INCLUDES CHECKLIST ==================== -->
  <section class="lp-includes" aria-labelledby="lp-includes-title">
    <div class="lp-section__inner">
      <h2 id="lp-includes-title" class="lp-section__title">{t.includesTitle}</h2>
      <ul class="lp-includes__list">
        {t.includes.map((item) => (
          <li data-anim="fade-up"><span class="lp-includes__check" aria-hidden="true">✓</span> {item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ==================== TESTIMONIALS ==================== -->
  <section class="lp-quotes" aria-labelledby="lp-quotes-title">
    <div class="lp-section__inner">
      <h2 id="lp-quotes-title" class="lp-section__title">{t.quotesTitle}</h2>
      <div class="lp-quotes__grid">
        {t.quotes.map((review) => (
          <figure class="quote" data-anim="fade-up">
            <blockquote>{review.quote}</blockquote>
            <figcaption>{review.author}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== PRICING ANCHOR ==================== -->
  <section class="lp-price" aria-labelledby="lp-price-title">
    <div class="lp-price__inner" data-anim="fade-up">
      <p class="eyebrow eyebrow--inverse">{t.priceLabel}</p>
      <h2 id="lp-price-title" class="lp-price__title">{t.priceTitle}</h2>
      <p class="lp-price__copy">{t.priceCopy}</p>
      <a href="#lp-form" class="btn btn--primary btn--lg">{t.priceCta} <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <!-- ==================== FORM ==================== -->
  <section id="lp-form" class="lp-form" aria-labelledby="lp-form-title">
    <div class="lp-form__inner">
      <h2 id="lp-form-title" class="lp-section__title">{t.formTitle}</h2>
      <p class="lp-form__copy">{t.formCopy}</p>
      <form class="form js-intake-form" action="/api/contact" method="POST" data-form="LP — Camera repair Miami" data-locale={locale} data-sent={locale === 'es' ? '✓ Enviado' : '✓ Sent'} data-success={t.formSuccess} data-error={locale === 'es' ? 'No pudimos enviar tu solicitud. Inténtalo de nuevo o llámanos al (786) 763-2091.' : 'We could not send your request. Please try again or call us at (786) 763-2091.'}>
        <div class="form__row">
          <div class="form__field">
            <label for="lp-name">{t.fName} *</label>
            <input id="lp-name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="form__field">
            <label for="lp-phone">{t.fPhone} *</label>
            <input id="lp-phone" name="phone" type="tel" autocomplete="tel" required />
          </div>
        </div>
        <div class="form__row">
          <div class="form__field">
            <label for="lp-email">{t.fEmail} *</label>
            <input id="lp-email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="form__field">
            <label for="lp-camera">{t.fCamera}</label>
            <input id="lp-camera" name="camera" type="text" placeholder={t.fCameraPh} />
          </div>
        </div>
        <div class="form__row">
          <div class="form__field">
            <label for="lp-area">{t.fArea}</label>
            <input id="lp-area" name="area" type="text" autocomplete="postal-code" placeholder={t.fAreaPh} />
          </div>
          <div class="form__field">
            <label for="lp-contact">{t.fContact}</label>
            <select id="lp-contact" name="contact-method">
              {t.fContactOptions.map((option) => <option value={option}>{option}</option>)}
            </select>
          </div>
        </div>
        <button type="submit" class="btn btn--primary btn--lg lp-form__submit">{t.fSubmit}</button>
        <p class="form__note">{t.fNote}</p>
      </form>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="cta" aria-labelledby="lp-final-title">
    <div class="cta__inner">
      <h2 id="lp-final-title" class="cta__title">{t.finalTitle}</h2>
      <p class="cta__copy">{t.finalCopy}</p>
      <div class="cta__actions">
        <a href="tel:+17867632091" class="btn btn--primary btn--lg">{t.finalCta}</a>
      </div>
    </div>
  </section>
</Base>

<style is:global>
/* ============================================================
   LP — ad landing pages (shared .lp- styles, duplicated per LP)
   ============================================================ */
.lp-hero {
  padding: 150px var(--gutter) 70px;
  background: var(--color-fog-canvas);
  text-align: center;
}
.lp-hero__inner { max-width: 900px; margin: 0 auto; }
.lp-hero__title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: clamp(38px, 6.4vw, 76px);
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: var(--color-apple-ink);
  margin-bottom: 22px;
}
.lp-hero__sub {
  font-size: clamp(17px, 1.6vw, 21px);
  color: var(--color-graphite);
  line-height: 1.5;
  max-width: 58ch;
  margin: 0 auto 32px;
}
.lp-hero__cta { margin-bottom: 40px; }
.lp-badges {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
}
.lp-badges li {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: -0.1px;
  color: var(--color-charcoal);
  background: var(--color-pure-white);
  border: 1px solid var(--color-ash);
  border-radius: var(--r-chip);
  padding: 8px 16px;
}

.lp-section__inner {
  max-width: 1024px;
  margin: 0 auto;
}
.lp-section__title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: clamp(28px, 4vw, 48px);
  line-height: 1.08;
  letter-spacing: -0.015em;
  color: var(--color-apple-ink);
  margin-bottom: 36px;
}

/* Steps */
.lp-steps {
  padding: clamp(60px, 8vw, 110px) var(--gutter);
  background: var(--color-pure-white);
}
.lp-steps__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}
.lp-steps__step {
  background: var(--color-fog-canvas);
  border-radius: var(--r-card);
  padding: 30px 28px;
}
.lp-steps__num {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 600;
  color: var(--color-apple-ink);
  letter-spacing: 0.08em;
}
.lp-steps__step h3 {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 22px;
  letter-spacing: -0.015em;
  margin: 10px 0;
  color: var(--color-apple-ink);
}
.lp-steps__step p {
  font-size: 15px;
  color: var(--color-graphite);
  line-height: 1.5;
}
@media (max-width: 820px) {
  .lp-steps__grid { grid-template-columns: 1fr; }
}

/* Includes checklist */
.lp-includes {
  padding: clamp(60px, 8vw, 110px) var(--gutter);
  background: var(--color-fog-canvas);
}
.lp-includes__list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.lp-includes__list li {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  background: var(--color-pure-white);
  border-radius: 18px;
  padding: 18px 20px;
  font-size: 16px;
  color: var(--color-charcoal);
  line-height: 1.45;
}
.lp-includes__check {
  flex: none;
  width: 24px;
  height: 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 113, 227, 0.1);
  color: var(--color-apple-ink);
  font-size: 12px;
  font-weight: 700;
}
@media (max-width: 760px) {
  .lp-includes__list { grid-template-columns: 1fr; }
}

/* Testimonials */
.lp-quotes {
  padding: clamp(60px, 8vw, 110px) var(--gutter);
  background: var(--color-pure-white);
}
.lp-quotes__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}
.lp-quotes .quote { background: var(--color-fog-canvas); }
@media (max-width: 900px) {
  .lp-quotes__grid { grid-template-columns: 1fr; }
}

/* Pricing anchor */
.lp-price {
  padding: clamp(60px, 8vw, 110px) var(--gutter);
  background: var(--color-fog-canvas);
}
.lp-price__inner {
  max-width: 1024px;
  margin: 0 auto;
  background: var(--color-apple-ink);
  border-radius: var(--r-card);
  padding: clamp(40px, 6vw, 72px);
  text-align: center;
}
.lp-price__title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: clamp(28px, 4.4vw, 54px);
  line-height: 1.07;
  letter-spacing: -0.015em;
  color: var(--color-pure-white);
  margin-bottom: 16px;
}
.lp-price__copy {
  font-size: 16px;
  color: var(--color-slate);
  line-height: 1.55;
  max-width: 54ch;
  margin: 0 auto 28px;
}

/* Form */
.lp-form {
  padding: clamp(60px, 8vw, 110px) var(--gutter);
  background: var(--color-pure-white);
  scroll-margin-top: 90px;
}
.lp-form__inner { max-width: 720px; margin: 0 auto; }
.lp-form__copy {
  font-size: 17px;
  color: var(--color-graphite);
  line-height: 1.5;
  margin: -20px 0 28px;
}
.lp-form__submit {
  justify-content: center;
  width: 100%;
}
</style>
