---
import Base from '../../layouts/Base.astro';
import { localePath, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const p = (path: string) => localePath(locale, path);

const t = locale === 'es' ? {
  title: 'Tienda — Próximamente | Miami Photography Center',
  description: 'Nuestra tienda de cámaras y equipo usado, revisado y calibrado en el taller con garantía de 6 meses, estará disponible muy pronto. Escríbenos para consultar disponibilidad.',
  breadcrumbHome: 'Inicio',
  breadcrumbStore: 'Tienda',
  eyebrow: 'Tienda',
  heading: 'Próximamente',
  lede: 'Estamos preparando nuestra tienda de cámaras, lentes y accesorios usados — revisados y calibrados en el taller, con garantía de 6 meses y envíos a todo Estados Unidos.',
  ctaCopy: '¿Buscas equipo usado? Escríbenos y te avisamos en cuanto esté disponible.',
  ctaButton: 'Escríbenos por correo',
  mailSubject: 'Consulta de equipo usado',
} : {
  title: 'Store — Coming Soon | Miami Photography Center',
  description: 'Our store of used cameras and gear — inspected and serviced in-house with a 6-month warranty — is coming soon. Get in touch to ask about availability.',
  breadcrumbHome: 'Home',
  breadcrumbStore: 'Store',
  eyebrow: 'Store',
  heading: 'Coming soon',
  lede: 'We’re putting together our store of used cameras, lenses, and accessories — inspected and serviced in-house, with a 6-month warranty and US-wide shipping.',
  ctaCopy: 'Looking for used gear? Send us a note and we’ll let you know as soon as it’s live.',
  ctaButton: 'Email us',
  mailSubject: 'Used gear inquiry',
};

const mailto = `mailto:service@miamiphotographycenter.com?subject=${encodeURIComponent(t.mailSubject)}`;
---
<Base locale={locale} title={t.title} description={t.description}>
  <!-- ==================== PAGE HERO ==================== -->
  <header class="page-hero page-hero--bare">
    <div class="page-hero__inner">
      <nav class="breadcrumbs" aria-label={locale === 'es' ? 'Ruta de navegación' : 'Breadcrumb'}>
        <a href={p('/')}>{t.breadcrumbHome}</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{t.breadcrumbStore}</span>
      </nav>
      <h1 class="sr-only">{t.breadcrumbStore} — {t.heading}</h1>
    </div>
  </header>

  <!-- ==================== COMING SOON ==================== -->
  <section class="store-soon" aria-label={t.heading}>
    <div class="store-soon__inner" data-anim="fade-up">
      <p class="store-soon__eyebrow">{t.eyebrow}</p>
      <p class="store-soon__heading">{t.heading}</p>
      <p class="store-soon__lede">{t.lede}</p>
      <p class="store-soon__cta-copy">{t.ctaCopy}</p>
      <a href={mailto} class="store-soon__cta">{t.ctaButton} <span aria-hidden="true">→</span></a>
    </div>
  </section>
</Base>

<style is:global>
/* ============================================================
   STORE — coming soon
   ============================================================ */
.store-soon {
  padding: clamp(40px, 8vw, 110px) var(--gutter) var(--section-gap);
  background: var(--color-fog-canvas);
}
.store-soon__inner {
  max-width: 680px;
  margin: 0 auto;
  text-align: center;
}
.store-soon__eyebrow {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-apple-ink);
  margin-bottom: 14px;
}
.store-soon__heading {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(34px, 6vw, 60px);
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: var(--color-apple-ink);
  margin-bottom: 22px;
}
.store-soon__lede {
  font-size: clamp(16px, 2.2vw, 19px);
  line-height: 1.6;
  color: var(--color-graphite);
  margin-bottom: 28px;
}
.store-soon__cta-copy {
  font-size: 15px;
  color: var(--color-charcoal);
  margin-bottom: 22px;
}
.store-soon__cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  border-radius: var(--r-chip);
  background: var(--color-electric-blue);
  color: var(--color-apple-ink);
  font-weight: 600;
  font-size: 16px;
  transition: transform .25s var(--ease-out), opacity .25s var(--ease-out);
}
.store-soon__cta:hover { transform: translateY(-2px); opacity: 0.9; }
</style>
