---
import Base from '../../layouts/Base.astro';
import { localePath, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const p = (path: string) => localePath(locale, path);

const t = locale === 'es' ? {
  title: 'Membresía Anual MPC — Mantenimiento de Cámaras Todo el Año | Miami',
  description: 'Tu equipo, mantenido todo el año. Limpiezas de sensor programadas, visitas in situ, prioridad en reparaciones y descuentos. Planes para fotógrafos, estudios, escuelas y productoras en el sur de Florida.',
  breadcrumbHome: 'Inicio',
  breadcrumbServices: 'Servicios',
  breadcrumbCurrent: 'Membresía',
  heroEyebrow: 'Membresía Anual',
  heroTitle: 'Membresía Anual MPC.',
  heroLede: 'Tu equipo, mantenido todo el año. Un solo plan. Cuidado programado. Servicio prioritario.',
  heroCta1: 'Quiero ser miembro',
  heroCta2: 'Ver planes',
  benefitsEyebrow: 'Qué incluye',
  benefitsTitle: 'Todo lo que tu equipo necesita, programado.',
  benefits: [
    { title: 'Limpiezas de sensor al año', copy: 'Limpiezas programadas según tu plan — tu sensor nunca acumula meses de polvo.' },
    { title: 'Visitas In Situ', copy: 'Nuestra unidad móvil va a tu estudio o locación, incluida en tu plan.' },
    { title: 'Prioridad en reparaciones', copy: 'Tu equipo entra primero en la cola del taller. Menos tiempo sin trabajar.' },
    { title: 'Descuentos en reparaciones', copy: 'Tarifa preferencial de miembro en reparaciones adicionales.' },
    { title: 'Reporte anual de condición', copy: 'Un informe detallado del estado de cada cuerpo y lente cubierto.' },
    { title: 'Actualizaciones de firmware', copy: 'Mantenemos tu equipo al día en cada visita, sin costo extra.' },
  ],
  tiersEyebrow: 'Planes',
  tiersTitle: 'Tres planes. Un mismo estándar de cuidado.',
  tiersBadge: 'Más popular',
  tiersCta: 'Solicitar información',
  tiers: [
    {
      name: 'SOLO',
      who: 'Para fotógrafos individuales',
      program: 'Programa de membresía introductorio',
      accent: false,
      features: [
        'Visitas de servicio Camera Care',
        'Limpieza profesional de sensor',
        'Opciones de servicio in situ',
        'Agendamiento prioritario',
        'Cobertura diseñada según tu equipo',
      ],
