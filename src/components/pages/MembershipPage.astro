    'Sin reporte de condición de equipo',
  ],
  compareMember: 'Con la membresía',
  compareMemberItems: [
    'Limpiezas programadas, incluidas en el plan',
    'Visitas in situ incluidas según tu plan',
    'Prioridad en la cola de reparación',
    'Descuento de miembro en reparaciones',
    'Reporte anual de condición (planes Studio e Institution)',
  ],
  compareNote: 'Si cuidas tu equipo más de una vez al año, la membresía agrupa todo en un solo plan — con prioridad incluida.',
  whoEyebrow: 'Para quién es',
  whoTitle: 'Pensada para quienes viven de su equipo.',
  who: [
    { title: 'Fotógrafos', copy: 'Tu cámara es tu herramienta de trabajo. Mantenla lista todo el año.' },
    { title: 'Estudios', copy: 'Varios cuerpos y lentes, un solo plan de mantenimiento programado.' },
    { title: 'Escuelas', copy: 'Flotas de equipos para estudiantes, cuidadas con visitas regulares.' },
    { title: 'Productoras', copy: 'Soporte directo y mantenimiento por lotes para tu inventario.' },
  ],
  faqEyebrow: 'Preguntas frecuentes',
  faqTitle: 'Membresía, en claro.',
  faq: [
    { q: '¿Cuándo empieza mi membresía?', a: 'El día en que aprobamos tu solicitud y completamos la activación de la membresía. Desde ahí corre por 12 meses, con tus limpiezas y visitas programadas según el plan.' },
    { q: '¿Puedo cambiar de plan durante el año?', a: 'Sí. Contáctanos y te movemos al plan superior por el resto de tu período. Queremos que el plan se ajuste a tu equipo, no al revés.' },
    { q: '¿Qué equipos cubre?', a: 'Cuerpos de cámara y lentes, además de trípodes, equipos de iluminación, battery grips, accesorios y equipo de soporte — la cobertura se diseña según tu equipo o inventario. En la solicitud nos cuentas qué tienes y armamos el plan a tu medida.' },
    { q: '¿Cómo agendo mis limpiezas y visitas?', a: 'Por teléfono o email, con agenda prioritaria de miembro. También podemos dejar tus visitas programadas con fechas fijas desde el inicio.' },
  ],
  formEyebrow: 'Solicitud',
  formTitle: 'Aplica a la membresía.',
  formLede: 'Cuéntanos sobre tu equipo y el plan que te interesa. Te contactamos en un día hábil con los detalles del plan y los pasos siguientes.',
  formName: 'Nombre completo',
  formEmail: 'Email',
  formPhone: 'Teléfono',
  formTier: 'Plan que te interesa',
  formTierOptions: ['Solo — fotógrafo individual', 'Studio — estudio o producción pequeña', 'Institution — escuela o productora', 'Aún no lo sé'],
  formGear: '¿Cuántas cámaras y lentes?',
  formGearPh: 'Ej. 2 cuerpos, 4 lentes',
  formMessage: 'Mensaje',
  formMessagePh: 'Cuéntanos sobre tu equipo, tu ritmo de trabajo o cualquier pregunta...',
  formSubmit: 'Enviar solicitud',
  formNote: 'Programa introductorio. Te enviamos los detalles del plan al responder. Sin compromiso.',
  formSuccess: 'Solicitud recibida. Te contactamos en un día hábil con los detalles del plan y los pasos siguientes.',
  ctaTitle: '¿Dudas sobre qué plan te conviene?',
  ctaCopy: 'Llámanos y lo armamos contigo según tu equipo y tu ritmo de trabajo.',
  ctaBtn1: 'Llamar (786) 763-2091',
  ctaBtn2: 'Ver limpieza de sensor',
} : {
  title: 'MPC Annual Membership — Year-Round Camera Maintenance | Miami',
  description: 'Your gear, maintained year-round. Scheduled sensor cleanings, on-site visits, priority repairs, and member discounts. Plans for photographers, studios, schools, and production companies in South Florida.',
  breadcrumbHome: 'Home',
  breadcrumbServices: 'Services',
  breadcrumbCurrent: 'Membership',
  heroEyebrow: 'Annual Membership',
  heroTitle: 'MPC Annual Membership.',
  heroLede: 'Your gear, maintained year-round. One plan. Scheduled care. Priority service.',
  heroCta1: 'Become a Member',
  heroCta2: 'See plans',
  benefitsEyebrow: 'What’s included',
  benefitsTitle: 'Everything your gear needs, on a schedule.',
  benefits: [
    { title: 'Sensor cleanings per year', copy: 'Scheduled cleanings based on your plan — your sensor never collects months of dust.' },
    { title: 'On-site visits', copy: 'Our mobile unit comes to your studio or location, included in your plan.' },
    { title: 'Priority repair queue', copy: 'Your gear goes to the front of the workshop queue. Less time out of action.' },
    { title: 'Discounts on repairs', copy: 'Member pricing on any additional repairs your gear needs.' },
    { title: 'Annual gear condition report', copy: 'A detailed report on the state of every covered body and lens.' },
    { title: 'Firmware updates', copy: 'We keep your gear up to date at every visit, at no extra charge.' },
  ],
  tiersEyebrow: 'Plans',
  tiersTitle: 'Three plans. One standard of care.',
  tiersBadge: 'Most popular',
  tiersCta: 'Request info',
  tiers: [
    {
      name: 'SOLO',
      who: 'For Individual Photographers',
      program: 'Introductory membership program',
      accent: false,
      features: [
        'Camera Care service visits',
        'Professional Sensor Cleaning',
        'On-Site service options',
        'Priority scheduling',
        'Coverage designed around your equipment setup',
      ],
      footer: 'Let’s build a plan that fits your workflow.',
    },
    {
      name: 'STUDIO',
      who: 'For Studios & Small Production Teams',
      program: 'Introductory membership program',
      accent: true,
      features: [
        'Camera Care maintenance planning',
        'Professional Sensor Cleaning',
        'On-Site service availability',
        'Technical evaluations',
        'Equipment condition reporting',
        'Coverage designed around your equipment inventory',
      ],
      footer: 'Memberships tailored to the needs of your studio.',
    },
    {
      name: 'INSTITUTION',
      who: 'For Schools, Universities & Production Companies',
      program: 'Custom maintenance program',
      accent: false,
      features: [
        'Scheduled Camera Care services',
        'Professional Sensor Cleaning',
        'On-Site support programs',
        'Equipment condition reporting',
        'Dedicated technical coordination',
        'Coverage based on equipment inventory',
      ],
      footer: 'Designed around the operational requirements of your organization.',
    },
  ],
  compareEyebrow: 'The math',
  compareTitle: 'Service by service, or one plan.',
  compareSingle: 'Paying per service',
  compareSingleItems: [
    'Sensor cleaning from $89 per visit',
    'Travel fee on every on-site visit',
    'Standard repair queue',
    'Full price on every repair',
    'No gear condition report',
  ],
  compareMember: 'With membership',
  compareMemberItems: [
    'Scheduled cleanings included in the plan',
    'On-site visits included per your tier',
    'Priority repair queue',
    'Member discount on repairs',
    'Annual condition report (Studio & Institution)',
  ],
  compareNote: 'If you service your gear more than once a year, membership bundles it all into one plan — with priority built in.',
  whoEyebrow: 'Who it’s for',
  whoTitle: 'Built for people who work with their gear.',
  who: [
    { title: 'Photographers', copy: 'Your camera is your livelihood. Keep it ready all year long.' },
    { title: 'Studios', copy: 'Multiple bodies and lenses, one scheduled maintenance plan.' },
    { title: 'Schools', copy: 'Student gear fleets, cared for with regular scheduled visits.' },
    { title: 'Production companies', copy: 'Direct support and batch maintenance for your inventory.' },
  ],
  faqEyebrow: 'FAQ',
  faqTitle: 'Membership, made clear.',
  faq: [
    { q: 'When does my membership start?', a: 'The day we approve your application and complete membership activation. It runs for 12 months from there, with your cleanings and visits scheduled per your plan.' },
    { q: 'Can I change tiers mid-year?', a: 'Yes. Contact us and we’ll move you up to the next tier for the remainder of your term. The plan should fit your gear — not the other way around.' },
    { q: 'What gear is covered?', a: 'Camera bodies and lenses, plus tripods, lighting equipment, battery grips, accessories, and support equipment — coverage designed around your setup or inventory. Tell us what you have in the application and we’ll size the plan to you.' },
    { q: 'How do I schedule my cleanings and visits?', a: 'By phone or email, with member-priority scheduling. We can also lock in your scheduled visits with fixed dates from day one.' },
  ],
  formEyebrow: 'Apply',
  formTitle: 'Apply for membership.',
  formLede: 'Tell us about your gear and the plan you’re interested in. We’ll get back within one business day with plan details and next steps.',
  formName: 'Full name',
  formEmail: 'Email',
  formPhone: 'Phone',
  formTier: 'Tier you’re interested in',
  formTierOptions: ['Solo — individual photographer', 'Studio — studio or small production', 'Institution — school or production company', 'Not sure yet'],
  formGear: 'How many cameras & lenses?',
  formGearPh: 'e.g. 2 bodies, 4 lenses',
  formMessage: 'Message',
  formMessagePh: 'Tell us about your gear, your workload, or any questions...',
  formSubmit: 'Send Application',
  formNote: 'Introductory program. We’ll send the plan details when we respond. No commitment.',
  formSuccess: 'Application received. We’ll contact you within one business day with plan details and next steps.',
  ctaTitle: 'Not sure which plan fits?',
  ctaCopy: 'Call us and we’ll size it with you, based on your gear and how you work.',
  ctaBtn1: 'Call (786) 763-2091',
  ctaBtn2: 'See sensor cleaning',
};

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
});
---
<Base locale={locale} title={t.title} description={t.description}>
  <script type="application/ld+json" set:html={faqSchema} slot="head" is:inline />

  <!-- ==================== PAGE HERO ==================== -->
  <header class="page-hero">
    <div class="page-hero__inner">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href={p('/')}>{t.breadcrumbHome}</a>
        <span aria-hidden="true">›</span>
        <a href={p('/services')}>{t.breadcrumbServices}</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{t.breadcrumbCurrent}</span>
      </nav>
      <p class="eyebrow" data-anim="fade-up">{t.heroEyebrow}</p>
      <h1 class="page-hero__title" data-anim="fade-up">{t.heroTitle}</h1>
      <p class="page-hero__lede" data-anim="fade-up">{t.heroLede}</p>
      <div class="members-hero__ctas" data-anim="fade-up">
        <a href="#membership-form" class="btn btn--primary">{t.heroCta1}</a>
        <a href="#plans" class="btn btn--ghost">{t.heroCta2} <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </header>

  <!-- ==================== BENEFITS CHECKLIST ==================== -->
  <section class="members-benefits" aria-labelledby="benefits-title">
    <div class="members-benefits__head">
      <p class="eyebrow">{t.benefitsEyebrow}</p>
      <h2 id="benefits-title" class="members-benefits__title">{t.benefitsTitle}</h2>
    </div>
    <ul class="members-benefits__grid">
      {t.benefits.map((item) => (
        <li class="members-benefits__item" data-anim="fade-up">
          <span class="members-check" aria-hidden="true">✓</span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- ==================== PRICING TIERS ==================== -->
  <section id="plans" class="members-tiers" aria-labelledby="tiers-title">
    <div class="members-tiers__head">
      <p class="eyebrow">{t.tiersEyebrow}</p>
      <h2 id="tiers-title" class="members-tiers__title">{t.tiersTitle}</h2>
    </div>
    <div class="members-tiers__grid">
      {t.tiers.map((tier) => (
        <article class={`card members-tier${tier.accent ? ' card--accent' : ''}`} data-anim="fade-up">
          <div class="card__inner members-tier__inner">
            {tier.accent && <span class="members-tier__badge">{t.tiersBadge}</span>}
            <h3 class="members-tier__name">{tier.name}</h3>
            <p class="members-tier__who">{tier.who}</p>
            <p class="members-tier__program">{tier.program}</p>
            <ul class="members-tier__list">
              {tier.features.map((feature) => (
                <li><span class="members-check members-check--sm" aria-hidden="true">✓</span>{feature}</li>
              ))}
            </ul>
            <p class="members-tier__foot">{tier.footer}</p>
            <a href="#membership-form" class={`btn ${tier.accent ? 'btn--primary' : 'btn--ghost'} members-tier__cta`}>{t.tiersCta}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ==================== COMPARISON STRIP ==================== -->
  <section class="members-compare" aria-labelledby="compare-title">
    <div class="members-compare__inner">
      <div class="members-compare__head">
        <p class="eyebrow eyebrow--inverse">{t.compareEyebrow}</p>
        <h2 id="compare-title" class="members-compare__title">{t.compareTitle}</h2>
      </div>
      <div class="members-compare__grid">
        <div class="members-compare__col" data-anim="fade-up">
          <h3>{t.compareSingle}</h3>
          <ul>
            {t.compareSingleItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="members-compare__col members-compare__col--member" data-anim="fade-up">
          <h3>{t.compareMember}</h3>
          <ul>
            {t.compareMemberItems.map((item) => (
              <li><span class="members-check members-check--sm" aria-hidden="true">✓</span>{item}</li>
            ))}
          </ul>
        </div>
      </div>
      <p class="members-compare__note" data-anim="fade-up">{t.compareNote}</p>
    </div>
  </section>

  <!-- ==================== WHO IT'S FOR ==================== -->
  <section class="members-who" aria-labelledby="who-title">
    <div class="members-who__head">
      <p class="eyebrow">{t.whoEyebrow}</p>
      <h2 id="who-title" class="members-who__title">{t.whoTitle}</h2>
    </div>
    <ul class="members-who__grid">
      {t.who.map((item) => (
        <li class="members-who__card" data-anim="fade-up">
          <h3>{item.title}</h3>
          <p>{item.copy}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- ==================== FAQ ACCORDION ==================== -->
  <section class="members-faq" aria-labelledby="faq-title">
    <div class="members-faq__inner">
      <div class="members-faq__head">
        <p class="eyebrow">{t.faqEyebrow}</p>
        <h2 id="faq-title" class="members-faq__title">{t.faqTitle}</h2>
      </div>
      <div class="members-faq__list">
        {t.faq.map((item, i) => (
          <div class="members-faq__item">
            <h3>
              <button
                type="button"
                class="members-faq__q"
                id={`members-faq-q${i}`}
                aria-expanded="false"
                aria-controls={`members-faq-a${i}`}
              >
                {item.q}
                <span class="members-faq__icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div class="members-faq__a" id={`members-faq-a${i}`} role="region" aria-labelledby={`members-faq-q${i}`} hidden>
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== APPLY FORM ==================== -->
  <section class="members-form" aria-labelledby="apply-title">
    <div class="members-form__inner">
      <div class="members-form__intro">
        <p class="eyebrow">{t.formEyebrow}</p>
        <h2 id="apply-title" class="members-form__title">{t.formTitle}</h2>
        <p class="members-form__lede">{t.formLede}</p>
      </div>
      <form id="membership-form" class="form js-intake-form" action="/api/contact" method="POST" data-form="Membership application" data-locale={locale} data-success={t.formSuccess} data-error={locale === 'es' ? 'No pudimos enviar tu solicitud. Inténtalo de nuevo o llámanos al (786) 763-2091.' : 'We could not send your request. Please try again or call us at (786) 763-2091.'}>
        <div class="form__row">
          <div class="form__field">
            <label for="mf-name">{t.formName} *</label>
            <input id="mf-name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="form__field">
            <label for="mf-email">{t.formEmail} *</label>
            <input id="mf-email" name="email" type="email" autocomplete="email" required />
          </div>
        </div>
        <div class="form__row">
          <div class="form__field">
            <label for="mf-phone">{t.formPhone} *</label>
            <input id="mf-phone" name="phone" type="tel" autocomplete="tel" required />
          </div>
          <div class="form__field">
            <label for="mf-tier">{t.formTier}</label>
            <select id="mf-tier" name="tier">
              {t.formTierOptions.map((opt) => <option value={opt}>{opt}</option>)}
            </select>
          </div>
        </div>
        <div class="form__field">
          <label for="mf-gear">{t.formGear}</label>
          <input id="mf-gear" name="gear" type="text" placeholder={t.formGearPh} />
        </div>
        <div class="form__field">
          <label for="mf-message">{t.formMessage}</label>
          <textarea id="mf-message" name="message" placeholder={t.formMessagePh}></textarea>
        </div>
        <div>
          <button type="submit" class="btn btn--primary btn--lg">{t.formSubmit}</button>
        </div>
        <p class="form__note">{t.formNote}</p>
      </form>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="cta" aria-labelledby="cta-title">
    <div class="cta__inner">
      <h2 id="cta-title" class="cta__title">{t.ctaTitle}</h2>
      <p class="cta__copy">{t.ctaCopy}</p>
      <div class="cta__actions">
        <a href="tel:+17867632091" class="btn btn--primary btn--lg">{t.ctaBtn1}</a>
        <a href={p('/sensor-cleaning')} class="btn btn--ghost btn--lg">{t.ctaBtn2}</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      function initMembersFaq() {
        var faq = document.querySelector('.members-faq');
        if (!faq || faq.dataset.faqInit === '1') return;
        faq.dataset.faqInit = '1';
        var buttons = faq.querySelectorAll('.members-faq__q');
        buttons.forEach(function (btn) {
          btn.addEventListener('click', function () {
            var wasOpen = btn.getAttribute('aria-expanded') === 'true';
            buttons.forEach(function (b) {
              b.setAttribute('aria-expanded', 'false');
              var panel = document.getElementById(b.getAttribute('aria-controls'));
              if (panel) panel.hidden = true;
              var icon = b.querySelector('.members-faq__icon');
              if (icon) icon.textContent = '+';
            });
            if (!wasOpen) {
              btn.setAttribute('aria-expanded', 'true');
              var open = document.getElementById(btn.getAttribute('aria-controls'));
              if (open) open.hidden = false;
              var openIcon = btn.querySelector('.members-faq__icon');
              if (openIcon) openIcon.textContent = '−';
            }
          });
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMembersFaq);
      } else {
        initMembersFaq();
      }
    })();
  </script>
</Base>

<style is:global>
/* ============================================================
   MEMBERSHIP PAGE (.members-)
   ============================================================ */
.members-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
}

/* Shared check bullet */
.members-check {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--color-electric-blue);
  color: var(--color-apple-ink);
  font-size: 14px;
  font-weight: 700;
}
.members-check--sm {
  width: 20px;
  height: 20px;
  font-size: 11px;
  margin-right: 10px;
}

/* Benefits checklist */
.members-benefits {
  padding: var(--section-gap) var(--gutter);
  background: var(--color-pure-white);
