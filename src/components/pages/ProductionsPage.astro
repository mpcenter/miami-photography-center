---
import Base from '../../layouts/Base.astro';
import { localePath, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const p = (path: string) => localePath(locale, path);

const t = locale === 'es' ? {
  title: 'Producciones de Foto y Video en Miami | Miami Photography Center',
  description: 'Servicios visuales creativos para marcas, negocios y profesionales en Miami. Fotografía gastronómica, de producto, retratos, cobertura de eventos y fotografía de naturaleza.',
  breadcrumbHome: 'Inicio',
  breadcrumbServices: 'Servicios',
  breadcrumbCurrent: 'Producciones',
  heroEyebrow: 'Producciones',
  heroTitle: 'Producciones de foto y video.',
  heroLede: 'Servicios visuales creativos para marcas, negocios y profesionales.',
  heroCta1: 'Planifica tu producción',
  heroCta2: 'Ver servicios',
  servicesEyebrow: 'Servicios destacados',
