---
import Base from '../../layouts/Base.astro';
import { localePath, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const p = (path: string) => localePath(locale, path);

interface LegalSection {
  h: string;
  ps: string[];
  bullets?: string[];
}

const t = locale === 'es' ? {
  title: 'Política de Privacidad | Miami Photography Center',
  description: 'Política de privacidad de Miami Photography Center: qué información recopilamos a través de nuestros formularios, cómo la usamos y cómo la protegemos. No vendemos tus datos.',
  heroEyebrow: 'Legal',
  heroTitle: 'Política de Privacidad.',
  draftNote: 'Borrador de trabajo — el texto final está sujeto a revisión legal.',
  updated: 'Última actualización: junio de 2026',
  sections: [
    {
      h: 'Resumen',
      ps: [
        'Miami Photography Center («MPC», «nosotros») opera el sitio miamiphotographycenter.com y ofrece servicios de reparación de cámaras, mantenimiento, servicio on-site y producciones de foto y video en el sur de Florida. Esta política explica qué información recopilamos, cómo la usamos y qué opciones tienes sobre ella.',
      ],
    },
    {
      h: 'Información que recopilamos',
      ps: [
        'Recopilamos la información que tú nos proporcionas directamente a través de los formularios del sitio (contacto, solicitud de reparación, agendamiento) y por teléfono o email. Esto puede incluir:',
      ],
      bullets: [
        'Nombre completo',
        'Email y número de teléfono',
        'Ubicación o área de servicio',
        'Marca, modelo y descripción del equipo, y detalles del problema',
        'El contenido de tu mensaje',
      ],
    },
    {
      h: 'Cómo usamos tu información',
      ps: ['Usamos esta información únicamente para:'],
      bullets: [
        'Responder a tus consultas y solicitudes de servicio',
        'Procesar y dar seguimiento a reparaciones, recogidas, envíos y visitas on-site',
        'Enviarte actualizaciones sobre el estado de tu servicio (diagnóstico, presupuesto, retorno)',
        'Mejorar nuestros servicios y la experiencia del sitio',
      ],
    },
    {
      h: 'No vendemos tus datos',
      ps: [
        'No vendemos ni alquilamos tu información personal a terceros. Compartimos datos solo con los proveedores necesarios para operar nuestro servicio — por ejemplo, transportistas para envíos, procesadores de pago y proveedores de email u hosting — y únicamente en la medida necesaria. También podemos divulgar información cuando la ley lo requiera.',
      ],
    },
    {
      h: 'Cookies y analítica',
      ps: [
        'El sitio puede usar cookies y herramientas de analítica para entender cómo se utiliza y mejorar el contenido. Estas herramientas recopilan información agregada, como páginas visitadas y tipo de dispositivo. Puedes desactivar las cookies en la configuración de tu navegador; el sitio seguirá funcionando.',
      ],
    },
    {
      h: 'Retención y seguridad de los datos',
      ps: [
        'Conservamos tu información solo durante el tiempo necesario para prestarte el servicio y cumplir con obligaciones legales o contables. Aplicamos medidas razonables para proteger tus datos, aunque ningún método de transmisión o almacenamiento es 100 % seguro.',
      ],
    },
    {
      h: 'Tus derechos',
      ps: [
        'Puedes solicitar acceso, corrección o eliminación de tu información personal en cualquier momento escribiendo a service@miamiphotographycenter.com.',
      ],
    },
    {
      h: 'Menores de edad',
      ps: [
        'Nuestros servicios no están dirigidos a menores de 13 años y no recopilamos intencionalmente información de menores.',
      ],
    },
    {
      h: 'Cambios a esta política',
      ps: [
        'Podemos actualizar esta política ocasionalmente. Cualquier cambio se publicará en esta página con la fecha de actualización.',
      ],
    },
  ] as LegalSection[],
  contactH: 'Contacto',
  contactP: 'Si tienes preguntas sobre esta política, escríbenos a',
  contactEnd: 'o llámanos al +1 (786) 763-2091. Dirección: 3911 SW 27th St, West Park, FL 33023.',
  backLabel: 'Volver al inicio',
} : {
  title: 'Privacy Policy | Miami Photography Center',
  description: 'Miami Photography Center privacy policy: what information we collect through our forms, how we use it, and how we protect it. We do not sell your data.',
  heroEyebrow: 'Legal',
  heroTitle: 'Privacy Policy.',
  draftNote: 'Working draft — final text subject to legal review.',
  updated: 'Last updated: June 2026',
  sections: [
    {
      h: 'Overview',
      ps: [
        'Miami Photography Center (“MPC”, “we”) operates miamiphotographycenter.com and provides camera repair, maintenance, on-site service, and photo & video production services across South Florida. This policy explains what information we collect, how we use it, and the choices you have.',
      ],
    },
    {
      h: 'Information we collect',
      ps: [
        'We collect information you provide directly through the forms on this site (contact, repair request, scheduling) and by phone or email. This may include:',
      ],
      bullets: [
        'Full name',
        'Email address and phone number',
        'Location or service area',
        'Equipment brand, model, and issue description',
        'The contents of your message',
      ],
    },
    {
      h: 'How we use your information',
      ps: ['We use this information solely to:'],
      bullets: [
        'Respond to your inquiries and service requests',
        'Process and track repairs, pickups, shipments, and on-site visits',
        'Send you updates about the status of your service (diagnostic, quote, return)',
        'Improve our services and the site experience',
      ],
    },
    {
      h: 'We do not sell your data',
      ps: [
        'We do not sell or rent your personal information to third parties. We share data only with the providers needed to operate our service — for example, shipping carriers, payment processors, and email or hosting providers — and only to the extent necessary. We may also disclose information when required by law.',
      ],
    },
    {
      h: 'Cookies & analytics',
      ps: [
        'This site may use cookies and analytics tools to understand how it is used and to improve content. These tools collect aggregate information such as pages visited and device type. You can disable cookies in your browser settings; the site will continue to work.',
      ],
    },
    {
      h: 'Data retention & security',
      ps: [
        'We keep your information only as long as needed to provide your service and to meet legal or accounting obligations. We apply reasonable safeguards to protect your data, though no method of transmission or storage is 100% secure.',
      ],
    },
    {
      h: 'Your rights',
      ps: [
        'You may request access to, correction of, or deletion of your personal information at any time by writing to service@miamiphotographycenter.com.',
      ],
    },
    {
      h: 'Children',
      ps: [
        'Our services are not directed at children under 13, and we do not knowingly collect information from children.',
      ],
    },
    {
      h: 'Changes to this policy',
      ps: [
        'We may update this policy from time to time. Any changes will be posted on this page with an updated date.',
      ],
    },
  ] as LegalSection[],
  contactH: 'Contact',
  contactP: 'If you have questions about this policy, write to us at',
  contactEnd: 'or call +1 (786) 763-2091. Address: 3911 SW 27th St, West Park, FL 33023.',
  backLabel: 'Back to home',
};
---
<Base locale={locale} title={t.title} description={t.description}>

  <!-- ==================== HERO ==================== -->
  <header class="page-hero">
    <div class="page-hero__inner">
      <p class="eyebrow" data-anim="fade-up">{t.heroEyebrow}</p>
      <h1 class="page-hero__title" data-anim="fade-up">{t.heroTitle}</h1>
    </div>
  </header>

  <!-- ==================== LEGAL PROSE ==================== -->
  <article class="legal">
    <div class="legal__inner">
      <p class="legal-note">{t.draftNote}</p>
      <p class="legal-updated">{t.updated}</p>

      {t.sections.map((section) => (
        <section class="legal-section">
          <h2>{section.h}</h2>
          {section.ps.map((para) => <p>{para}</p>)}
          {section.bullets && (
            <ul>
              {section.bullets.map((item) => <li>{item}</li>)}
            </ul>
          )}
        </section>
      ))}

      <section class="legal-section">
        <h2>{t.contactH}</h2>
        <p>
          {t.contactP}
          {' '}<a href="mailto:service@miamiphotographycenter.com">service@miamiphotographycenter.com</a>{' '}
          {t.contactEnd}
        </p>
      </section>

      <p class="legal-back"><a href={p('/')}>← {t.backLabel}</a></p>
    </div>
  </article>
</Base>

<style is:global>
/* ============================================================
   LEGAL PAGES (shared prose styles)
   ============================================================ */
.legal {
  padding: 20px var(--gutter) var(--section-gap);
}
.legal__inner {
  max-width: 720px;
  margin: 0 auto;
}
.legal-note {
  display: inline-block;
  padding: 8px 16px;
  border-radius: var(--r-chip);
  background: rgba(0, 113, 227, 0.08);
  border: 1px solid rgba(0,0,0,0.22);
  color: var(--color-apple-ink);
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 14px;
}
.legal-updated {
  font-size: 14px;
  color: var(--color-slate);
  margin-bottom: 40px;
}
.legal-section { margin-bottom: 40px; }
.legal-section h2 {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: clamp(21px, 2.2vw, 26px);
  letter-spacing: -0.02em;
  line-height: 1.2;
  color: var(--color-apple-ink);
  margin-bottom: 14px;
}
.legal-section p {
  font-size: 16px;
  line-height: 1.65;
  color: var(--color-charcoal);
}
.legal-section p + p { margin-top: 12px; }
.legal-section a {
  color: var(--color-apple-ink);
}
.legal-section a:hover { text-decoration: underline; }
.legal-section ul {
  margin-top: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.legal-section ul li {
  font-size: 16px;
  line-height: 1.55;
  color: var(--color-charcoal);
  padding-left: 22px;
  position: relative;
}
.legal-section ul li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.6em;
  width: 10px;
  height: 2px;
  border-radius: 2px;
  background: var(--color-electric-blue);
}
.legal-back { margin-top: 56px; font-size: 15px; }
.legal-back a {
  color: var(--color-apple-ink);
  font-weight: 600;
}
.legal-back a:hover { text-decoration: underline; }
</style>
